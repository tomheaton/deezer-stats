    "react-chartjs-2": "^5.2.0",
    "react-dom": "19.2.4",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
